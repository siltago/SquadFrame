# Variáveis de ambiente do SGI
# Copie este arquivo para .env.local e preencha os valores
# NUNCA commite o .env.local — apenas este .env.example

# ─── Supabase ───────────────────────────────────────────────
# Encontre em: Supabase Dashboard > Settings > API

# URL do projeto (pública — pode aparecer no browser)
NEXT_PUBLIC_SUPABASE_URL=

# Chave anon/pública (pública — pode aparecer no browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave service_role (SECRETA — nunca expor no client-side)
# Usada apenas em server actions e server components
SUPABASE_SERVICE_ROLE_KEY=
