# Variáveis de ambiente do SGI
# Copie este arquivo para .env.local e preencha os valores
# NUNCA commite o .env.local — apenas este .env.example

# ─── Supabase ───────────────────────────────────────────────
# Encontre em: Supabase Dashboard > Settings > API

# URL do projeto (pública — pode aparecer no browser)
NEXT_PUBLIC_SUPABASE_URL=

# Chave anon/pública (pública — pode aparecer no browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave service_role (SECRETA — nunca expor no client-side)
# Usada apenas em server actions e server components
SUPABASE_SERVICE_ROLE_KEY=

# ─── Cron ───────────────────────────────────────────────────
# Segredo usado para autenticar chamadas do Vercel Cron aos jobs em
# app/api/cron/* (enviado como header "Authorization: Bearer <valor>").
# Gere uma string aleatória qualquer.
CRON_SECRET=

# ─── WhatsApp (Twilio) ──────────────────────────────────────
# API oficial do WhatsApp Business via Twilio — usada pra verificação de
# número no Perfil e pra cobrança de prazos. Painel: https://console.twilio.com

# Account SID (Twilio Console > Account Info)
TWILIO_ACCOUNT_SID=

# Auth Token (Twilio Console > Account Info)
TWILIO_AUTH_TOKEN=

# Número remetente do WhatsApp, só dígitos com DDI, sem "+" (sandbox:
# 14155238886 — ou o número aprovado do seu WhatsApp Business Sender)
TWILIO_WHATSAPP_FROM=

# Content SID de um template aprovado na Meta (Twilio Console > Content
# Template Builder), com 1 variável recebendo o texto inteiro da mensagem.
# Obrigatório em produção (fora da janela de 24h/sandbox); pode ficar vazio
# em dev/sandbox, onde a mensagem vai como texto livre.
TWILIO_CONTENT_SID=

# Templates com botão CTA (call-to-action) para as mensagens de cobrança de
# prazos — mesma ideia do TWILIO_CONTENT_SID acima, mas do tipo
# "twilio/call-to-action" (2 variáveis: {{1}} texto, {{2}} parte dinâmica da
# URL). Sem eles configurados, a cobrança cai de volta pro texto livre com o
# link embutido na mensagem.
TWILIO_CONTENT_SID_CTA_PEDIDO=
TWILIO_CONTENT_SID_CTA_SOLICITACAO=
